# ============================================================
# ViralGen AI — Environment Configuration
# Copy this file to .env and fill in your actual keys
# ============================================================

# --- OpenAI (GPT-4) ---
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Stability AI ---
STABILITY_API_KEY=sk-your-stability-ai-api-key-here

# --- Redis (for Celery task queue) ---
REDIS_URL=redis://localhost:6379/0

# --- MongoDB (for history/persistence) ---
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=viralgen

# --- App Settings ---
APP_SECRET_KEY=change-this-to-a-random-secret-key
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Image Storage ---
# "local" stores images in backend/static/generated/
# "url"   stores only the URL returned by Stability AI
IMAGE_STORAGE_MODE=local
STATIC_DIR=static/generated
